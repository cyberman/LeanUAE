#!/bin/sh
# --------------------------------------------------------------------------------------------------
set -e
# --------------------------------------------------------------------------------------------------

"$BUILD_ENV_DIR/packages/zlib"

PACKAGE=libpng-1.6.48
PACKAGE_REVISION=0
CHECKSUM=46fd06ff37db1db64c0dc288d78a3f5efd23ad9ac41561193f983e20937ece03

# --------------------------------------------------------------------------------------------------
. "$PACKAGE_PRE"
# --------------------------------------------------------------------------------------------------

"$BUILD_ENV_DIR/scripts/download.py" \
https://downloads.sourceforge.net/project/libpng/libpng16/\
1.6.48/$PACKAGE.tar.xz \
sha256:$CHECKSUM

tar xf "$BUILD_ENV_DIR/_sources/$PACKAGE.tar.xz"
cd $PACKAGE

./configure --prefix=$PREFIX
make
make install

# --------------------------------------------------------------------------------------------------
. "$PACKAGE_POST"
# --------------------------------------------------------------------------------------------------
